# Scout MCP Server Configuration

# Required: Scout Live API key
SCOUT_API_KEY=your-api-key-here

# Optional: Scout Live API URL (default: https://scoutos.live)
SCOUT_API_URL=https://scoutos.live

# Optional: Transport mode (stdio, http, sse)
# stdio = local/CLI use
# http = HTTP/SSE server for remote access
MCP_TRANSPORT=http

# Optional: Server port (default: 3000)
PORT=3000